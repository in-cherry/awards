generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 1. GESTÃO DO SAAS (DONOS DE RIFAS)
// ==========================================

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String // Para login de admin
  phone     String?  @unique
  cpf       String?  @unique
  avatarUrl String?
  role      UserRole @default(USER)

  tenants Tenant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Tenant {
  id      String @id @default(cuid())
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  name            String
  slug            String  @unique
  customDomain    String? @unique
  logoUrl         String?
  faviconUrl      String?
  metaTitle       String?
  metaDescription String?
  instagramUrl    String?
  telegramUrl     String?
  supportUrl      String?
  isActive        Boolean @default(true)
  homeView        String  @default("RAFFLE") // RAFFLE (mostra rifa principal) ou LIST (mostra lista de rifas)

  // Mercado Pago — split de pagamentos (OAuth do tenant)
  mpAccessToken String? // Access token MP do tenant (OAuth)
  mpRecipientId String? // ID do recebedor no MP (collector_id)

  raffles           Raffle[]
  clients           Client[]
  payments          Payment[]
  verificationCodes VerificationCode[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tenants")
}

// ==========================================
// 2. AUTENTICAÇÃO OTP
// ==========================================

model VerificationCode {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  email     String
  code      String
  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([tenantId, email])
  @@map("verification_codes")
}

// ==========================================
// 3. CLIENTES FINAIS (COMPRADORES)
// ==========================================

model Client {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  name  String @db.VarChar(250)
  cpf   String @db.VarChar(20)
  phone String @db.VarChar(20)
  email String @db.VarChar(250)

  payments Payment[]
  tickets  Ticket[]

  wonRaffles       Raffle[]             @relation("RaffleWinner")
  wonMysteryPrizes MysteryPrizeWinner[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, cpf])
  @@index([cpf])
  @@map("clients")
}

// ==========================================
// 4. CAMPANHAS E BILHETES
// ==========================================

model Raffle {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  slug         String
  title        String
  description  String?      @db.Text
  bannerUrl    String?
  price        Decimal      @db.Decimal(10, 2)
  minNumbers   Int          @default(1)
  totalNumbers Int
  status       RaffleStatus @default(DRAFT)
  drawDate     DateTime?

  // Contador atômico para alocação eficiente de tickets (zero colisões)
  // nextTicketNumber começa em 1 e vai sendo incrementado atomicamente
  nextTicketNumber Int @default(1)

  // Ganhador Principal
  winnerId String?
  winner   Client? @relation("RaffleWinner", fields: [winnerId], references: [id])

  // Mystery Box Config (armazenado como JSON pelo dono da rifa)
  // Ex: { rules: [{minTickets:400,boxes:1},{minTickets:600,boxes:2}], winProbability: 0.1 }
  mysteryBoxEnabled Boolean @default(false)
  mysteryBoxConfig  Json?

  payments      Payment[]
  tickets       Ticket[]
  mysteryPrizes MysteryPrize[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, slug])
  @@map("raffles")
}

model Ticket {
  id        String  @id @default(cuid())
  raffleId  String
  raffle    Raffle  @relation(fields: [raffleId], references: [id])
  clientId  String
  client    Client  @relation(fields: [clientId], references: [id])
  paymentId String
  payment   Payment @relation(fields: [paymentId], references: [id])

  // Inteiro para máxima eficiência em rifas com até 1M+ números
  number          Int
  numberFormatted String @db.VarChar(6)

  createdAt DateTime @default(now())

  @@unique([raffleId, number])
  @@unique([raffleId, numberFormatted])
  @@index([clientId])
  @@index([paymentId])
  @@map("tickets")
}

// ==========================================
// 5. CAIXA MISTERIOSA
// ==========================================

model MysteryPrize {
  id       String @id @default(cuid())
  raffleId String
  raffle   Raffle @relation(fields: [raffleId], references: [id], onDelete: Cascade)

  title       String
  description String?

  totalAmount Int
  remaining   Int

  winners MysteryPrizeWinner[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("mystery_prizes")
}

model MysteryPrizeWinner {
  id String @id @default(cuid())

  prizeId String
  prize   MysteryPrize @relation(fields: [prizeId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  paymentId String
  payment   Payment @relation(fields: [paymentId], references: [id])

  // Índice do box (0, 1, 2...) dentro do pagamento
  boxIndex Int @default(0)

  // Número do ticket que destravou (inteiro)
  ticketNumber Int

  awardedAt DateTime @default(now())

  @@map("mystery_prize_winners")
}

// ==========================================
// 6. FINANCEIRO
// ==========================================

model Payment {
  id           String        @id @default(cuid())
  externalId   String?       @unique // ID do Mercado Pago
  status       PaymentStatus @default(PENDING)
  amount       Decimal       @db.Decimal(10, 2)
  ticketCount  Int // Quantos bilhetes foram comprados neste pedido
  qrCode       String?       @db.Text
  qrCodeBase64 String?       @db.Text

  // Caixas Misteriosas concedidas neste pedido (calculado no webhook)
  boxesGranted Int @default(0)

  // Metadata adicional para armazenar informações do Mercado Pago e split payment
  metadata Json?

  // Campo para armazenar quando o pagamento foi processado
  processedAt DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  raffleId String
  raffle   Raffle @relation(fields: [raffleId], references: [id])
  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  tickets    Ticket[]
  mysteryWon MysteryPrizeWinner[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([externalId])
  @@index([tenantId])
  @@index([clientId])
  @@map("payments")
}

// ==========================================
// ENUMS
// ==========================================

enum UserRole {
  USER
  ADMIN
}

enum RaffleStatus {
  DRAFT
  ACTIVE
  FINISHED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  APPROVED
  CANCELLED
  REFUNDED
}
