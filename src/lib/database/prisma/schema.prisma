generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- NÚCLEO DE USUÁRIOS ---

model User {
  id                  String             @id
  email               String             @unique
  password            String
  name                String
  phone               String
  cpf                 String             @unique
  isActive            Boolean            @default(true)
  emailVerifiedAt     DateTime?
  lastLoginAt         DateTime?
  profile             Profile?
  ownedTenants        Tenant[]           @relation("OwnerTenants")
  memberTenants       TenantMember[]
  sentMemberInvites   TenantMember[]     @relation("InviteRelation")
  sentExternalInvites TenantInvite[]     @relation("InviteRelation")
  verificationCodes   VerificationCode[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@map("users")
}

model Profile {
  id       String  @id @default(uuid())
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String  @unique
  nickname String?
  avatar   String?
  banner   String?
  slug     String? @unique

  @@map("profiles")
}

// --- ESTRUTURA SAAS (TENANT) ---

model Tenant {
  id              String  @id @default(uuid())
  owner           User    @relation("OwnerTenants", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId         String
  name            String
  slug            String  @unique
  customDomain    String? @unique
  metaTitle       String?
  metaDescription String? @db.Text
  logo            String?
  favicon         String?
  instagram       String?
  telegram        String?
  supportUrl      String?

  connections Connection[]
  members     TenantMember[]
  invites     TenantInvite[]
  clients     Client[]
  raffles     Raffle[]
  awards      Award[]
  tickets     Ticket[]
  payments    Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tenants")
}

model Connection {
  id                String           @id @default(cuid())
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId          String
  provider          String
  providerAccountId String
  publicEmail       String?
  accessToken       String           @db.Text
  refreshToken      String?          @db.Text
  expiresAt         DateTime?
  status            ConnectionStatus @default(ACTIVE)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([tenantId, provider])
  @@map("connections")
}

// --- GESTÃO DE TIME ---

model TenantMember {
  id          String     @id @default(uuid())
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId    String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  role        TenantRole
  invitedBy   User?      @relation("InviteRelation", fields: [invitedById], references: [id], onDelete: SetNull)
  invitedById String?
  acceptedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime   @default(now())

  @@unique([tenantId, userId])
  @@index([tenantId, role])
  @@map("tenant_members")
}

model TenantInvite {
  id          String     @id @default(uuid())
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId    String
  email       String
  role        TenantRole
  invitedBy   User?      @relation("InviteRelation", fields: [invitedById], references: [id], onDelete: SetNull)
  invitedById String?
  acceptedAt  DateTime?
  canceledAt  DateTime?
  createdAt   DateTime   @default(now())

  @@map("tenant_invites")
}

// --- VENDAS E SORTEIOS ---

model Client {
  id       String @id @default(cuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId String
  name     String
  cpf      String
  email    String
  phone    String

  emailVerifiedAt   DateTime?
  lastLoginAt       DateTime?
  profile           ClientProfile?
  verificationCodes VerificationCode[]
  payments          Payment[]
  tickets           Ticket[]
  awards            Award[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, cpf])
  @@unique([tenantId, email])
  @@map("clients")
}

model VerificationCode {
  id        String                  @id @default(cuid())
  codeHash  String
  purpose   VerificationCodePurpose
  email     String
  user      User?                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String?
  client    Client?                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime                @default(now())

  @@index([email, purpose])
  @@index([userId, purpose])
  @@index([clientId, purpose])
  @@index([expiresAt])
  @@map("verification_codes")
}

model ClientProfile {
  id       String  @id @default(uuid())
  client   Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String  @unique
  nickname String?
  avatar   String?
  banner   String?
  slug     String? @unique

  @@map("client_profiles")
}

model Raffle {
  id          String       @id @default(uuid())
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId    String
  name        String
  slug        String
  description String?      @db.Text
  banner      String?
  status      RaffleStatus @default(DRAFT)
  drawDate    DateTime?
  finishedAt  DateTime?
  pixValue    Decimal      @db.Decimal(10, 2)
  priceTicket Decimal      @db.Decimal(10, 2)
  minTickets  Int          @default(1)
  maxTickets  Int

  awards  Award[]
  tickets Ticket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId, createdAt])
  @@map("raffles")
}

model Ticket {
  id        String   @id @default(cuid())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId  String
  raffle    Raffle   @relation(fields: [raffleId], references: [id], onDelete: Cascade)
  raffleId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String
  number    Int
  payment   Payment? @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  paymentId String?

  awards    Award[]
  createdAt DateTime @default(now())

  @@unique([raffleId, number])
  @@index([tenantId, raffleId])
  @@map("tickets")
}

model Payment {
  id       String @id @default(cuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  externalId String? @unique
  amount     Int
  totalValue Decimal @db.Decimal(10, 2)

  method PaymentMethod @default(PIX)
  status PaymentStatus @default(PENDING)

  tickets   Ticket[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@map("payments")
}

model Award {
  id       String @id @default(cuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  name         String
  type         AwardType
  claimedType  AwardClaimType @default(PRODUCT)
  awardedValue Decimal?       @db.Decimal(10, 2)

  raffle   Raffle? @relation(fields: [raffleId], references: [id], onDelete: SetNull)
  raffleId String?
  ticket   Ticket? @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  ticketId String?

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@map("awards")
}

// --- ENUMS ---

enum ConnectionStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum TenantRole {
  OWNER
  ADMIN
  MEMBER
}

enum AwardType {
  RAFFLE_WINNER
  INSTANT_PRIZE
  CONSOLATION_PRIZE
}

enum AwardClaimType {
  PRODUCT
  PIX
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  PIX
  BOLETO
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELED
}

enum VerificationCodePurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  LOGIN
}

enum RaffleStatus {
  DRAFT
  ACTIVE
  FINISHED
  CANCELED
}
